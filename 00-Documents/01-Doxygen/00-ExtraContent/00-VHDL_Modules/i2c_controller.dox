--!   {name: "SCL", wave: "01010101010101010101010101010101010101" , period: 2},
--!   { name: "SDA",  wave: "0........................1...0...0...1...0...............1...0.......0...0.1..",},
--!   { name: "clk cycle",  wave: "0.5.0.5.0.5.0.5.0.5.0.5.0.5.0.5.0.3.0.5.0.5.0.5.0.5.0.5.0.5.0.5.0.5.0.3.0.9.0.", data:"1 2 3 4 5 6 7 8 9 1 2 3 4 5 6 7 8 9 1 2 3 4 5 6 7 8 9 1 2 3 4 5 6 7 8 9 1"}
--! ],
--!   config: { hscale: 1, skin: 'narrow'},
