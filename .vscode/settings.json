{
    "workbench.iconTheme": "material-icon-theme",
    "git.autofetch": true,
    "git.openRepositoryInParentFolders": "always",
    "highlight.regexes": {
        "(--!.*)": {
            "filterLanguageRegex": "vhdl",
            "decorations": [
                {
                    "color": "#444444"
                }
            ]
        }
    },
    "latex-workshop.latex.tools": [
        {
            "name": "pdflatex",
            "command": "pdflatex",
            "args": [
                "-synctex=1",
                "-interaction=nonstopmode",
                "-file-line-error",
                "-output-directory=%DIR%/report/build",
                "-aux-directory=%DIR%/report/build",
                "%DOC%"
            ]
        },
        {
            "name": "bibtex-vicon",
            "command": "powershell",
            "args": [
                "-Command",
                "$env:BIBINPUTS='%DIR%'; Push-Location '%DIR%/report/build'; bibtex main; Pop-Location"
            ]
        }
    ],
    "latex-workshop.latex.recipes": [
        {
            "name": "Compilar con Bibliografía",
            "tools": [
            "pdflatex",
            "bibtex-vicon",
            "pdflatex",
            "pdflatex"
            ]
        }
    ],
"latex-workshop.latex.outDir": "%DIR%/report/build",
"latex-workshop.latex.autoClean.run": "never",
"latex-workshop.latex.autoBuild.run": "never",
"latex-workshop.latex.clean.method": "glob",
"latex-workshop.latex.clean.fileTypes": [],
}