{
    "workbench.iconTheme": "material-icon-theme",
    "git.autofetch": true,
    "git.openRepositoryInParentFolders": "always",
    "highlight.regexes": {
        "(--!.*)": {
            "filterLanguageRegex": "vhdl",
            "decorations": [
                {
                    "color": "#444444"
                }
            ]
        }
    },
     "latex-workshop.latex.tools": [
        {
            "name": "pdflatex",
            "command": "pdflatex",
            "args": [
                "-synctex=1",
                "-interaction=nonstopmode",
                "-file-line-error",
                "-output-directory=%DIR%/report/build",
                "%DOC%"
            ]
        },
        {
            "name": "bibtex-bibliography",
            "command": "powershell",
            "args": [
                "-Command",
                "Push-Location '%DIR%/report/build'; bibtex FrontBackMatter/Bibliography; Pop-Location"
            ]
        }
    ],
    "latex-workshop.latex.recipes": [
        {
            "name": "Compilar con Bibliografía",
            "tools": [
                "pdflatex",
                "bibtex-bibliography",
                "pdflatex",
                "pdflatex"
            ]
        }
    ],
    "latex-workshop.latex.recipe.default": "Compilar con Bibliografía",
    "latex-workshop.latex.outDir": "%DIR%/report/build",
    "latex-workshop.latex.clean.enabled": false,
    "latex-workshop.latex.autoClean.run": "never"
}